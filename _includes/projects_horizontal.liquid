<div class="col mb-3">
  <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
    <div class="card hoverable project-card-horizontal">
      <div class="card-body py-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div class="d-flex align-items-center flex-wrap" style="gap: 0.4rem;">
            <div style="width: 6rem; flex-shrink: 0; display: flex; justify-content: center;">
              {% if project.company %}
                <span class="badge company-tag company-{{ project.company | slugify }}" style="font-size: 0.7rem;">{{ project.company }}</span>
              {% endif %}
            </div>
            <span class="card-title h5 mb-0 font-weight-bold">{{ project.title }}</span>
          </div>
        </div>
        <p class="card-text mt-2 mb-0 text-muted small">{{ project.description }}</p>
      </div>
    </div>
  </a>
</div>
